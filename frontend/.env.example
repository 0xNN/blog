# Frontend (Vite) — HANYA variabel ber-prefix VITE_ yang dibaca app & ikut ke browser.
# Isi nilai ASLI di frontend/.env (gitignored), JANGAN di file .example ini (ini di-commit).
#
# JANGAN PERNAH menaruh SECRET/SERVICE_ROLE key di frontend — itu akan ter-bundle ke
# browser = akses penuh ke DB Anda. Secret hanya untuk Edge Functions (auto-injected).

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# anon key (atau "publishable key" gaya baru sb_publishable_...) — aman dipublik
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key
VITE_EDGE_FUNCTIONS_URL=https://YOUR_PROJECT_REF.functions.supabase.co
