{
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "devCommand": "npm run dev",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://ztprwznueobxgytulzdi.functions.supabase.co/api/:path*" },
    { "source": "/r/:path*", "destination": "https://ztprwznueobxgytulzdi.functions.supabase.co/redirect/:path*" },
    { "source": "/ads.txt", "destination": "https://ztprwznueobxgytulzdi.functions.supabase.co/seo/ads.txt" },
    { "source": "/sitemap.xml", "destination": "https://ztprwznueobxgytulzdi.functions.supabase.co/seo/sitemap.xml" },
    { "source": "/rss.xml", "destination": "https://ztprwznueobxgytulzdi.functions.supabase.co/seo/rss.xml" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
