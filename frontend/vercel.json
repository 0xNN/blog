{
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "devCommand": "npm run dev",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://ztprwznueobxgytulzdi.functions.supabase.co/api/:path*" },
    { "source": "/r/:path*", "destination": "https://ztprwznueobxgytulzdi.functions.supabase.co/redirect/:path*" },
    { "source": "/ads.txt", "destination": "https://ztprwznueobxgytulzdi.functions.supabase.co/seo/ads.txt" },
    { "source": "/sitemap.xml", "destination": "https://ztprwznueobxgytulzdi.functions.supabase.co/seo/sitemap.xml" },
    { "source": "/rss.xml", "destination": "https://ztprwznueobxgytulzdi.functions.supabase.co/seo/rss.xml" },
    { "source": "/robots.txt", "destination": "/robots.txt" },
    { "source": "/favicon.ico", "destination": "/favicon.ico" },
    { "source": "/favicon.svg", "destination": "/favicon.svg" },
    { "source": "/favicon-16.png", "destination": "/favicon-16.png" },
    { "source": "/favicon-32.png", "destination": "/favicon-32.png" },
    { "source": "/favicon-48.png", "destination": "/favicon-48.png" },
    { "source": "/favicon-96.png", "destination": "/favicon-96.png" },
    { "source": "/favicon-192.png", "destination": "/favicon-192.png" },
    { "source": "/favicon-512.png", "destination": "/favicon-512.png" },
    { "source": "/apple-touch-icon.png", "destination": "/apple-touch-icon.png" },
    { "source": "/apple-touch-icon.svg", "destination": "/apple-touch-icon.svg" },
    { "source": "/og-image.png", "destination": "/og-image.png" },
    { "source": "/og-image.svg", "destination": "/og-image.svg" },
    { "source": "/site.webmanifest", "destination": "/site.webmanifest" },
    { "source": "/google:file.html", "destination": "/google:file.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=900, s-maxage=3600" }
      ]
    },
    {
      "source": "/rss.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/rss+xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=900, s-maxage=3600" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-XSS-Protection", "value": "0" }
      ]
    }
  ]
}
