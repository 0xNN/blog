# --- Database (MongoDB Atlas M0) ---
# Ambil dari Atlas: Database > Connect > Drivers > connection string
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net
MONGO_URL=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net
DB_NAME=developer_hub

# --- Auth ---
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=GANTI_DENGAN_RANDOM_STRING

# --- Frontend (CORS + link absolut) ---
# URL frontend saat dev (CRACO default port 3000)
FRONTEND_URL=http://localhost:3000

# --- AI (Emergent) ---
# Kosongkan dulu kalau belum pakai fitur AI
EMERGENT_LLM_KEY=

# --- Email (Resend, opsional) ---
# Kosongkan -> welcome email jadi no-op (tidak error)
RESEND_API_KEY=

# --- Storage (opsional) ---
APP_NAME=developer-hub
